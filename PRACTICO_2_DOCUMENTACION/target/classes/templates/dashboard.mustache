<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-3xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
        {{/username}}
        {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido!</p>
        {{/username}}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Tu Perfil</h2>
                <p class="text-gray-600 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>
            
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Registrar Alumno</h2>
                <p class="text-gray-600 mb-4">Da de alta a un nuevo alumno.</p>
                <a href="/alumno/create" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Nuevo Alumno</a>
            </div>

            <div class="bg-purple-50 border border-purple-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-purple-700 mb-3">Registrar Profesor</h2>
                <p class="text-gray-600 mb-4">Da de alta a un nuevo profesor.</p>
                <a href="/profesor/create" class="inline-block bg-purple-600 text-white py-2 px-4 rounded-md hover:bg-purple-700 transition duration-300">Nuevo Profesor</a>
            </div>
        </div>

        <div class="mt-8 mb-8">
            <h3 class="text-2xl font-bold text-gray-800 mb-4 border-b pb-2">Alumnos Registrados</h3>
            <div class="bg-white shadow-sm overflow-hidden rounded-md border border-gray-200">
                <ul class="divide-y divide-gray-200">
                    {{#alumnos}}
                    <li class="px-6 py-4 hover:bg-gray-50 transition duration-150">
                        <div class="flex items-center justify-between">
                            <div class="text-lg font-medium text-blue-600 truncate">
                                {{nombre}} {{apellido}} 
                            </div>
                            <div class="ml-2 flex-shrink-0 flex">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                    DNI: {{dni}}
                                </span>
                            </div>
                        </div>
                        <div class="mt-1 text-sm text-gray-500">
                            Correo: {{correo}}
                        </div>
                    </li>
                    {{/alumnos}}
                    
                    {{^alumnos}}
                    <li class="px-6 py-6 text-center text-gray-500">
                        Aún no hay alumnos registrados en la base de datos.
                    </li>
                    {{/alumnos}}
                </ul>
            </div>
        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>