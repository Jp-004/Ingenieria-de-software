<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administración de Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.css">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-4 flex items-center justify-center">
        <div class="max-w-3xl w-full bg-white rounded-lg shadow-lg border border-gray-200 p-8">
            
            <div class="mb-6 text-center">
                <h1 class="text-3xl font-bold text-gray-800 mb-2">Administración de Materias</h1>
                <p class="text-gray-600">Listado y control de materias de la facultad</p>
            </div>

            <div class="border border-gray-200 rounded-lg overflow-hidden mb-8">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100 border-b border-gray-200 text-gray-700 text-sm font-semibold">
                            <th class="p-4">Nombre de la Materia</th>
                            <th class="p-4">Código</th>
                            <th class="p-4 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-gray-800">
                        {{#materias}}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="p-4 font-medium">{{nombre}}</td>
                            <td class="p-4"><span class="bg-gray-200 text-gray-700 px-2 py-1 rounded text-xs font-mono">{{codigo}}</span></td>
                            <td class="p-4 text-center">
                                <form action="/materias/eliminar" method="post" onsubmit="return confirm('¿Seguro querés eliminar esta materia?');" class="inline-block">
                                    <input type="hidden" name="materia_id" value="{{id}}">
                                    <button type="submit" class="bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-md text-sm font-medium transition">
                                        <i class="ti ti-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {{/materias}}
                        {{^materias}}
                        <tr>
                            <td colspan="3" class="p-8 text-center text-gray-500">
                                <i class="ti ti-folder-off text-4xl block mb-2 text-gray-400"></i>
                                No hay materias registradas en el sistema.
                            </td>
                        </tr>
                        {{/materias}}
                    </tbody>
                </table>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-2 border-t border-gray-100">
                <a href="/materias/nueva" class="w-full sm:w-auto flex items-center justify-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-medium shadow text-center">
                    <i class="ti ti-plus"></i> Crear Materia
                </a>
                <button class="w-full sm:w-auto bg-gray-500 text-white px-6 py-3 rounded-lg hover:bg-gray-600 transition font-medium shadow">
                    Despues Te Digo
                </button>
                <a href="/dashboard" class="w-full sm:w-auto text-center text-gray-500 hover:text-gray-700 transition font-medium py-2">
                    Volver
                </a>
            </div>

        </div>
    </div>
</body>
</html>