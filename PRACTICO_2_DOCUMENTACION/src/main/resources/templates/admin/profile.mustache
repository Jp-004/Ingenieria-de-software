<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-8">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Mi Perfil</h1>
            <button onclick="window.history.back()" class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700 transition">Volver Atrás</button>
        </div>

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 font-semibold text-center">{{errorMessage}}</div>
        {{/errorMessage}}
        
        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 font-semibold text-center">{{successMessage}}</div>
        {{/successMessage}}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-blue-500 h-fit">
                <h2 class="text-xl font-bold text-gray-700 mb-6 border-b pb-2">Información de la Cuenta</h2>
                
                {{#usuario}}
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-gray-500 font-semibold uppercase tracking-wide">Correo Electrónico</p>
                        <p class="text-lg text-gray-800 font-medium">{{name}}</p>
                    </div>
                    
                    <div>
                        <p class="text-sm text-gray-500 font-semibold uppercase tracking-wide">Rol en el Sistema</p>
                        <span class="inline-block mt-1 bg-blue-100 text-blue-800 text-sm px-3 py-1 rounded-full font-bold uppercase">{{rango}}</span>
                    </div>

                    <div>
                        <p class="text-sm text-gray-500 font-semibold uppercase tracking-wide">Último Acceso</p>
                        {{#ultimo_acceso}}
                            <p class="text-gray-800">{{ultimo_acceso}}</p>
                        {{/ultimo_acceso}}
                        {{^ultimo_acceso}}
                            <p class="text-gray-400 italic">Primer inicio de sesión</p>
                        {{/ultimo_acceso}}
                    </div>
                </div>
                {{/usuario}}
            </div>

            <div class="bg-white p-6 rounded-lg shadow-md border-t-4 border-purple-500">
                <h2 class="text-xl font-bold text-gray-700 mb-6 border-b pb-2">Cambiar Contraseña</h2>
                
                <form action="/profile/password" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Contraseña Actual:</label>
                        <input type="password" name="password_actual" required
                               class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-purple-500 focus:outline-none">
                    </div>

                    <hr class="my-4 border-gray-200">

                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Nueva Contraseña:</label>
                        <input type="password" name="password_nueva" required
                               class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-purple-500 focus:outline-none">
                    </div>

                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Confirmar Nueva Contraseña:</label>
                        <input type="password" name="password_confirmar" required
                               class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-purple-500 focus:outline-none">
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full bg-purple-600 text-white font-bold py-2 px-4 rounded hover:bg-purple-700 transition shadow-sm">
                            Actualizar Contraseña
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>