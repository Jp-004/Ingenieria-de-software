<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planes de Estudio - Consultar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.css">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-4">
        <div class="max-w-6xl mx-auto">
            <!-- Header -->
            <div class="mb-6 flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-800">Planes de Estudio</h1>
                    <p class="text-gray-600 mt-1">Listado de todos los planes registrados en el sistema</p>
                </div>
                
                <a href="{{backUrl}}" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition">
                    <i class="ti ti-arrow-left"></i>
                    Volver
                </a>
            </div>

            <!-- Messages -->
            {{#successMessage}}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-4">
                <span>{{successMessage}}</span>
            </div>
            {{/successMessage}}

            {{#errorMessage}}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
                <span>{{errorMessage}}</span>
            </div>
            {{/errorMessage}}

            <!-- Tabla -->
            <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
                {{#planes}}
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">ID</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">Año de Vigencia</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">Carrera</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">Estado</th>
                            <th class="px-6 py-3 text-center text-sm font-semibold text-gray-800">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        {{#.}}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 text-sm text-gray-700">{{id}}</td>
                            <td class="px-6 py-4 text-sm text-gray-700 font-medium">{{anio_vigencia}}</td>
                            <td class="px-6 py-4 text-sm text-gray-600">{{carrera_nombre}}</td>
                            <td class="px-6 py-4 text-sm">
                                {{#activo}}
                                <span class="inline-block px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full font-medium">Activo</span>
                                {{/activo}}
                                {{^activo}}
                                <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 text-xs rounded-full font-medium">Inactivo</span>
                                {{/activo}}
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex justify-center gap-2">
                                    <a href="/plan/edit?id={{id}}" class="inline-flex items-center gap-1 px-3 py-1 text-xs bg-blue-100 text-blue-600 rounded hover:bg-blue-200 transition">
                                        <i class="ti ti-edit"></i> Editar
                                    </a>
                                    <a href="/plan/delete?id={{id}}" class="inline-flex items-center gap-1 px-3 py-1 text-xs bg-red-100 text-red-600 rounded hover:bg-red-200 transition">
                                        <i class="ti ti-trash"></i> Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {{/.}}
                    </tbody>
                </table>
                {{/planes}}
                {{^planes}}
                <div class="p-8 text-center">
                    <i class="ti ti-inbox text-4xl text-gray-400 block mb-2"></i>
                    <p class="text-gray-600">No hay planes de estudio registrados</p>
                </div>
                {{/planes}}
            </div>

            <!-- Botón para crear -->
            <div class="mt-6 text-center">
                <a href="/plan/create" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
                    <i class="ti ti-plus"></i>
                    Crear Nuevo Plan
                </a>
            </div>
        </div>
    </div>
</body>
</html>
