<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Periodos de Exámenes</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-8">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Periodos de Exámenes</h1>
            <a href="/dashboard" class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700 transition">Volver al Panel</a>
        </div>

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 font-semibold text-center">{{errorMessage}}</div>
        {{/errorMessage}}
        
        {{#successMessage}}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4 font-semibold text-center">{{successMessage}}</div>
        {{/successMessage}}

        <div class="bg-white p-6 rounded-lg shadow-md mb-8 border-t-4 border-yellow-500">
            <h2 class="text-xl font-bold text-gray-700 mb-4">Crear Nuevo Periodo</h2>
            
            <form action="/gestion/periodos/create" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                
                <div class="md:col-span-2">
                    <label class="block text-gray-700 font-medium mb-1">Descripción del Periodo:</label>
                    <input type="text" name="descripcion" placeholder="Ej: Primeros Parciales 2026 - Sistemas" required
                           class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-yellow-500">
                </div>

                <div class="md:col-span-2">
                    <label class="block text-gray-700 font-medium mb-1">Tipo de Examen:</label>
                    <select name="tipo" required class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-yellow-500 bg-white">
                        <option value="Parcial">Exámenes Parciales</option>
                        <option value="Final">Exámenes Finales</option>
                    </select>
                </div>

                <div>
                    <label class="block text-gray-700 font-medium mb-1">Fecha de Inicio:</label>
                    <input type="date" name="fecha_inicio" required class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-yellow-500">
                </div>

                <div>
                    <label class="block text-gray-700 font-medium mb-1">Fecha de Fin:</label>
                    <input type="date" name="fecha_fin" required class="w-full px-4 py-2 border rounded focus:ring-2 focus:ring-yellow-500">
                </div>

                <div class="md:col-span-2 mt-2">
                    <button type="submit" class="w-full bg-yellow-600 text-white font-bold py-2 px-4 rounded hover:bg-yellow-700 transition">
                        Guardar Periodo
                    </button>
                </div>
            </form>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md">
            <h2 class="text-xl font-bold text-gray-700 mb-4">Periodos Configurados</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 border-b">
                            <th class="p-3 text-gray-600 text-sm uppercase tracking-wider">Descripción</th>
                            <th class="p-3 text-gray-600 text-sm uppercase tracking-wider">Tipo</th>
                            <th class="p-3 text-gray-600 text-sm uppercase tracking-wider">Inicio</th>
                            <th class="p-3 text-gray-600 text-sm uppercase tracking-wider">Fin</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y text-gray-700">
                        {{#periodos}}
                        <tr class="hover:bg-gray-50">
                            <td class="p-3 font-medium">{{descripcion}}</td>
                            <td class="p-3">
                                <span class="bg-gray-200 text-gray-800 text-xs px-2 py-1 rounded font-bold uppercase">{{tipo}}</span>
                            </td>
                            <td class="p-3">{{fecha_inicio}}</td>
                            <td class="p-3">{{fecha_fin}}</td>
                        </tr>
                        {{/periodos}}
                        
                        {{^periodos}}
                        <tr>
                            <td colspan="4" class="p-4 text-center text-gray-500">Aún no hay periodos de exámenes configurados.</td>
                        </tr>
                        {{/periodos}}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</body>
</html>