<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Materia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.css">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-4 flex items-center justify-center">
        <div class="max-w-2xl w-full bg-white rounded-lg shadow-lg border border-gray-200 p-8">
            
            <div class="mb-8 text-center">
                <h1 class="text-3xl font-bold text-gray-800 mb-2">Registrar Nueva Materia</h1>
                <p class="text-gray-600">Completa los datos académicos y técnicos de la asignatura</p>
            </div>

            <form action="/materias/guardar-completa" method="post" class="space-y-5">
                
                <div>
                    <label for="nombre" class="block text-sm font-semibold text-gray-800 mb-2">
                        <i class="ti ti-book text-blue-600 mr-1"></i> Nombre de la Materia
                    </label>
                    <input type="text" id="nombre" name="nombre" required placeholder="Ej: Ingenieria de Software II"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                </div>

                <div>
                    <label for="codigo" class="block text-sm font-semibold text-gray-800 mb-2">
                        <i class="ti ti-barcode text-blue-600 mr-1"></i> Código de la Materia
                    </label>
                    <input type="text" id="codigo" name="codigo" required placeholder="Ej: 3387"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                </div>

                <div>
                    <label for="docente_id" class="block text-sm font-semibold text-gray-800 mb-2">
                        <i class="ti ti-user-check text-blue-600 mr-1"></i> Docente Asignado
                    </label>
                    <select id="docente_id" name="docente_id" required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
                        <option value="" disabled selected>Seleccioná un Profesor...</option>
                        {{#docentes}}
                        <option value="{{id}}">{{nombre}} {{apellido}} (DNI: {{dni}})</option>
                        {{/docentes}}
                    </select>
                </div>

                <div class="flex gap-3 pt-4 border-t border-gray-100">
                    <button type="submit" class="flex-1 flex items-center justify-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-medium">
                        <i class="ti ti-device-floppy"></i> Guardar Materia
                    </button>
                    <a href="/materias/panel-gestion" class="flex-1 flex items-center justify-center gap-2 bg-gray-200 text-gray-800 px-6 py-3 rounded-lg hover:bg-gray-300 transition font-medium">
                        <i class="ti ti-x"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>