<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carreras - Consultar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.css">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-4">
        <div class="max-w-6xl mx-auto">
            <div class="mb-6 flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-800">Carreras</h1>
                    <p class="text-gray-600 mt-1">Listado de todas las carreras registradas</p>
                </div>
                <a href="/gestion/carreras" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition">
                    <i class="ti ti-arrow-left"></i>
                    Volver
                </a>
            </div>

            {{#successMessage}}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg mb-4">
                <span>{{successMessage}}</span>
            </div>
            {{/successMessage}}

            {{#errorMessage}}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-4">
                <span>{{errorMessage}}</span>
            </div>
            {{/errorMessage}}

            <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">ID</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">Nombre</th>
                            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-800">Código</th>
                            <th class="px-6 py-3 text-center text-sm font-semibold text-gray-800">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        {{#carreras}}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 text-sm text-gray-700">{{id}}</td>
                            <td class="px-6 py-4 text-sm text-gray-700 font-medium">{{nombre}}</td>
                            <td class="px-6 py-4 text-sm text-gray-600">{{codigo}}</td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex justify-center gap-2">
                                    <a href="/plan/list?carrera_id={{id}}&from=carrera" class="inline-flex items-center gap-1 px-3 py-1 text-xs bg-indigo-100 text-indigo-700 rounded hover:bg-indigo-200 transition">
                                        <i class="ti ti-list"></i> Planes
                                    </a>

                                    <a href="/carrera/edit?id={{id}}" class="inline-flex items-center gap-1 px-3 py-1 text-xs bg-blue-100 text-blue-600 rounded hover:bg-blue-200 transition">
                                        <i class="ti ti-edit"></i> Editar
                                    </a>
                                    
                                    <form action="/carrera/delete" method="post" onsubmit="return confirm('¿Seguro que quieres eliminar esta carrera?');" class="m-0 flex">
                                        <input type="hidden" name="id" value="{{id}}">
                                        <button type="submit" class="inline-flex items-center gap-1 px-3 py-1 text-xs bg-red-100 text-red-600 rounded hover:bg-red-200 transition">
                                            <i class="ti ti-trash"></i> Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {{/carreras}}
                        
                        {{^carreras}}
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-500">
                                <i class="ti ti-inbox text-4xl block mb-2 text-gray-400"></i>
                                <p class="text-gray-600">No hay carreras registradas</p>
                            </td>
                        </tr>
                        {{/carreras}}
                    </tbody>
                </table>
            </div>

            <div class="mt-6 text-center">
                <a href="/carrera/create" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">
                    <i class="ti ti-plus"></i>
                    Crear Nueva Carrera
                </a>
            </div>
        </div>
    </div>
</body>
</html>