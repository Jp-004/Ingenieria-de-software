<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Plan de Estudio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.css">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-4 flex items-center justify-center">
        <div class="max-w-md w-full bg-white rounded-lg shadow border border-gray-200 p-8">
            
            <div class="mb-6 flex items-center justify-between">
                <h1 class="text-2xl font-bold text-gray-800">Nuevo Plan</h1>
                <a href="/plan/list" class="text-gray-500 hover:text-gray-700 transition">
                    <i class="ti ti-x text-xl"></i>
                </a>
            </div>

            {{#errorMessage}}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6">
                <span>{{errorMessage}}</span>
            </div>
            {{/errorMessage}}

            <form action="/plan/create" method="POST" class="space-y-4">
                
                <div>
                    <label for="anio_vigencia" class="block text-sm font-medium text-gray-700 mb-1">Año de Vigencia</label>
                    <input type="number" id="anio_vigencia" name="anio_vigencia" required 
       min="1900" max="2100" placeholder="Ej: 2026"
       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                </div>

                <div>
                    <label for="carrera_id" class="block text-sm font-medium text-gray-700 mb-1">Carrera Asociada</label>
                    <select id="carrera_id" name="carrera_id" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none bg-white transition">
                        <option value="" disabled selected>Selecciona una carrera...</option>
                        {{#carreras}}
                            <option value="{{id}}">{{nombre}} ({{codigo}})</option>
                        {{/carreras}}
                        {{^carreras}}
                            <option value="" disabled>No hay carreras registradas</option>
                        {{/carreras}}
                    </select>
                </div>

                <div class="flex items-center mt-4 mb-6">
                    <input type="checkbox" id="activo" name="activo" checked
                        class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                    <label for="activo" class="ml-2 block text-sm text-gray-700">
                        Plan Activo
                    </label>
                </div>

                <div class="flex gap-4 mt-6">
                    <a href="{{cancelUrl}}" 
                       class="w-1/2 text-center px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition font-medium">
                        Cancelar
                    </a>
                    
                    <button type="submit" class="w-1/2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium flex items-center justify-center gap-2">
                        <i class="ti ti-device-floppy"></i> Guardar
                    </button>
                </div>
            </form>
            
        </div>
    </div>
</body>
</html>