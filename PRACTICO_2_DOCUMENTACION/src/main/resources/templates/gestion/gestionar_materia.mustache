<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administración de Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons@latest/tabler-icons.min.css">
</head>
<body class="bg-gray-50">
    <div class="min-h-screen p-4">
        <div class="max-w-4xl mx-auto">
            
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-gray-800 mb-2">Administración de Materias</h1>
                    <p class="text-gray-600">Listado, alta y baja de las materias de la facultad</p>
                </div>
                <a href="/materias/nueva" class="flex items-center justify-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-lg hover:bg-blue-700 transition font-medium shadow">
                    <i class="ti ti-plus"></i> Nueva Materia
                </a>
            </div>

            <div class="bg-white rounded-lg shadow border border-gray-200 overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-100 border-b border-gray-200 text-gray-700 text-sm font-semibold">
                            <th class="p-4">Nombre</th>
                            <th class="p-4">Código</th>
                            <th class="p-4 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 text-gray-800">
                        {{#materias}}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="p-4 font-medium">{{nombre}}</td>
                            <td class="p-4"><span class="bg-gray-200 text-gray-700 px-2 py-1 rounded text-xs font-mono">{{codigo}}</span></td>
                            <td class="p-4 flex justify-center gap-2">
                                <form action="/materias/eliminar" method="post" onsubmit="return confirm('¿Seguro querés eliminar esta materia?');">
                                    <input type="hidden" name="materia_id" value="{{id}}">
                                    <button type="submit" class="flex items-center gap-1 bg-red-100 text-red-700 hover:bg-red-200 px-3 py-1.5 rounded-md text-sm font-medium transition">
                                        <i class="ti ti-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {{/materias}}
                        {{^materias}}
                        <tr>
                            <td colspan="3" class="p-8 text-center text-gray-500">
                                <i class="ti ti-folder-off text-4xl block mb-2 text-gray-400"></i>
                                No hay ninguna materia registrada todavía.
                            </td>
                        </tr>
                        {{/materias}}
                    </tbody>
                </table>
            </div>

            <div class="mt-6">
                <a href="/dashboard" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-800 transition font-medium">
                    <i class="ti ti-arrow-left"></i> Volver al Panel de Control
                </a>
            </div>

        </div>
    </div>
</body>
</html>